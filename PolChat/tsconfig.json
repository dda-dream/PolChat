{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "ES2020", /* Современный JS для браузеров */
    "module": "ES2020", /* Модули */
    "lib": [ "DOM", "ES2020" ], /* Важно! Чтобы работали window, document, io */
    "outDir": "./static", /* Куда класть готовые .js файлы */
    "rootDir": "./static", /* Откуда брать .ts файлы */
    "strict": true, /* Строгая проверка типов */
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true, /* Совместимость импортов */
    "skipLibCheck": true, /* Пропускать проверки библиотек */
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true, /* true - Показывает ошибки и не генерирует JS-файлы */
    "sourceMap": true, /* Важно для отладки в браузере (см. пункт 3) */

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true

  },
  "include": [ "static/chat.ts", "static/global.d.ts" ],
  "exclude": [ "node_modules" ]
}
